# =====================================================================
# Personal Operations Dashboard — environment template
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# =====================================================================

# ---- App ----
APP_BASE_URL=http://localhost:3000          # public URL of the web app (used in OAuth redirects)
API_BASE_URL=http://localhost:4000          # the Fastify backend
APP_TIMEZONE=Asia/Riyadh                    # your timezone — used for date parsing in voice capture
PORT=4000

# ---- Supabase (Database + Storage + Auth) ----
# Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=                          # public anon key (frontend)
SUPABASE_SERVICE_ROLE_KEY=                  # secret service-role key (backend ONLY — never ship to client)
# Project Settings -> Database -> Connection string (for running migrations)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---- Anthropic API (voice parser + chat) ----
ANTHROPIC_API_KEY=
ANTHROPIC_PARSER_MODEL=claude-sonnet-4-6    # primary parsing
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001  # cheaper routes

# ---- Google Calendar (personal) — Google Cloud Console -> APIs & Services -> Credentials ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/google/callback

# ---- Microsoft 365 / Outlook (Badael work) — Entra ID app registration ----
# Azure Portal -> Microsoft Entra ID -> App registrations
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common                         # "common" works for personal+work; or your Badael tenant id
MS_REDIRECT_URI=http://localhost:4000/api/calendar/microsoft/callback

# ---- Capture tokens (mobile shortcuts, Phase 2) ----
CAPTURE_TOKEN_PEPPER=                        # random 64+ char string; used to hash capture tokens

# ---- Optional: Pushover notifications ----
PUSHOVER_TOKEN=
PUSHOVER_USER=
